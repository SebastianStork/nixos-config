{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "semanticCommits": "disabled",
  "enabledManagers": ["nix"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "commitMessageAction": "flake.lock: Update",
    "schedule": ["* 4 * * 2,4,6"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Disable per-input PRs; use full lock-file maintenance only",
      "matchManagers": ["nix"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    }
  ]
}
